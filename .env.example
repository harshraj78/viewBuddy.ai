# App
APP_NAME=AI Interview Copilot
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:8501,http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=8501

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_interview_copilot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg://postgres:change_me@localhost:5432/ai_interview_copilot

# Auth
JWT_SECRET_KEY=replace_with_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_HASH_SCHEME=argon2

# File Uploads
UPLOAD_DIR=./data/uploads
MAX_RESUME_FILE_MB=10
ALLOWED_RESUME_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# LLM Provider
LLM_PROVIDER=openai
INTERVIEW_LLM_PROVIDER=fallback
AI_EVALUATION_MODE=fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
LOCAL_LLM_BASE_URL=http://localhost:8001/v1
LOCAL_LLM_API_KEY=EMPTY
LOCAL_LLM_MODEL=interview-llm
LLM_REQUEST_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3

# Embeddings / Vector DB
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
VECTOR_DB_PROVIDER=chroma
CHROMA_HOST=localhost
CHROMA_PORT=8001
PINECONE_API_KEY=
PINECONE_INDEX_NAME=ai-interview-copilot

# Background Jobs
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Observability
LOG_LEVEL=INFO
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Rate Limiting
RATE_LIMIT_AUTH_PER_MINUTE=5
RATE_LIMIT_LLM_PER_HOUR=50
RATE_LIMIT_UPLOADS_PER_DAY=10

# Security
SECRET_KEY_ROTATION_VERSION=1
ENABLE_SECURE_COOKIES=false
TRUSTED_HOSTS=localhost,127.0.0.1
